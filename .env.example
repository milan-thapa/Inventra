# ============================================
# INVENTRA — Environment Variables
# Copy this file to .env.local and fill in
# ============================================

# ── DATABASE (Neon PostgreSQL) ──────────────
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/inventra?sslmode=require"

# ── AUTH.JS v5 ──────────────────────────────
AUTH_SECRET="run: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com)
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# GitHub OAuth (https://github.com/settings/developers)
AUTH_GITHUB_ID="your-github-client-id"
AUTH_GITHUB_SECRET="your-github-client-secret"

# ── EMAIL (Resend) ──────────────────────────
# Get API key at https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="noreply@inventra.com"

# ── FILE UPLOADS (Uploadthing) ──────────────
# Get keys at https://uploadthing.com
UPLOADTHING_SECRET="sk_live_xxxxxxxxxxxxxxxxxxxx"
UPLOADTHING_APP_ID="your-uploadthing-app-id"

# ── APP ─────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Inventra"
