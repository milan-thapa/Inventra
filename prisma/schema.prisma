// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ─────────────────────────────────────────
// AUTH.JS REQUIRED MODELS
// ─────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  profiles Profile[]
  notifications Notification[]
  notificationPreferences NotificationPreference[]
  stockMovements StockMovement[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────
// PROFILE (Business or Personal)
// ─────────────────────────────────────────

model Profile {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         ProfileType @default(BUSINESS)
  name         String
  category     String?
  logo         String?
  address      String?

  // Settings
  currency       String      @default("Rs.")
  currencyPos    String      @default("start") // "start" | "end"
  language       String      @default("en")    // "en" | "ne"
  calendarType   CalendarType @default(AD)
  dateFormat     String      @default("DD MMM YYYY")
  timeFormat     String      @default("12h")
  numberFormat   String      @default("indian") // "indian" | "international"
  theme          String      @default("dark")   // "dark" | "light" | "classic"
  privacyMode    Boolean     @default(false)
  appLock        Boolean     @default(false)
  
  // Tax Settings
  taxEnabled      Boolean     @default(false)
  taxType         String      @default("GST") // "GST" | "VAT" | "SALES_TAX"
  taxRate         Decimal     @default(0) @db.Decimal(5, 2) // Tax percentage
  taxNumber       String?     // GSTIN/VAT number

  // Barcode Settings
  barcodeEnabled  Boolean     @default(false)

  // Subscription
  subscriptionPlan      String   @default("trial")
  subscriptionEnd       DateTime?
  stripeCustomerId      String?
  stripeSubscriptionId  String?

  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  parties           Party[]
  expenses          Expense[]
  incomes           Income[]
  bankAccounts      BankAccount[]
  reminders         Reminder[]
  billImages        BillImage[]
  notes             Note[]
  expenseCategories ExpenseCategory[]
  incomeCategories  IncomeCategory[]
  transactions      Transaction[]
  notifications     Notification[]
  notificationPreferences NotificationPreference[]
  items             Item[]
  sales             Sale[]
  payments          Payment[]
  purchases         Purchase[]
  itemCategories    ItemCategory[]
  quotations        Quotation[]
  salesReturns      SalesReturn[]
  discounts         Discount[]
  purchaseReturns   PurchaseReturn[]
  stockMovements    StockMovement[]

  @@index([userId])
}

enum ProfileType {
  BUSINESS
  PERSONAL
}
enum CalendarType {
  AD
  BS
}

// ─────────────────────────────────────────
// PARTIES (Customers / Suppliers)
// ─────────────────────────────────────────

model Party {
  id             String      @id @default(cuid())
  profileId      String
  profile        Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name           String
  phone          String?
  email          String?
  address        String?
  panNumber      String?
  photo          String?
  openingBalance Decimal     @default(0) @db.Decimal(15, 2)
  openingDate    DateTime    @default(now())
  balanceType    BalanceType @default(TO_RECEIVE)
  creditLimit    Decimal     @default(0) @db.Decimal(15, 2)
  type           PartyType   @default(CUSTOMER) // "CUSTOMER" | "SUPPLIER" | "BOTH"
  deletedAt      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  partyTransactions PartyTransaction[]
  sales             Sale[]
  purchases         Purchase[]
  quotations        Quotation[]
  salesReturns      SalesReturn[]
  payments          Payment[]
  purchaseReturns   PurchaseReturn[]
  suppliedItems     Item[] @relation("ItemSupplier")
  batchSupplies     ItemBatch[]

  @@index([profileId])
  @@index([profileId, deletedAt])
  @@index([profileId, balanceType])
  @@index([profileId, name])
  @@index([profileId, type])
  @@index([deletedAt])
}

enum BalanceType {
  TO_RECEIVE
  TO_GIVE
  SETTLED
}

enum PartyType {
  CUSTOMER
  SUPPLIER
  BOTH
}

model PartyTransaction {
  id            String        @id @default(cuid())
  partyId       String
  party         Party         @relation(fields: [partyId], references: [id], onDelete: Cascade)
  profileId     String
  receiptNumber Int
  type          PartyTxType
  amount        Decimal       @db.Decimal(15, 2)
  paymentMethod PaymentMethod @default(CASH)
  remarks       String?
  billImage     String?
  date          DateTime      @default(now())
  createdAt     DateTime      @default(now())

  @@index([partyId])
  @@index([profileId])
  @@index([profileId, type])
  @@index([profileId, date])
  @@index([partyId, date])
  @@unique([profileId, receiptNumber])
}

enum PartyTxType {
  PAYMENT_IN
  PAYMENT_OUT
  OPENING_BALANCE
  SALE
  PURCHASE
}
enum PaymentMethod {
  CASH
  BANK
}

// ─────────────────────────────────────────
// EXPENSE
// ─────────────────────────────────────────

model Expense {
  id            String          @id @default(cuid())
  profileId     String
  profile       Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  expenseNo     Int
  categoryId    String
  category      ExpenseCategory @relation(fields: [categoryId], references: [id])
  totalAmount   Decimal         @db.Decimal(15, 2)
  paymentMethod PaymentMethod   @default(CASH)
  remarks       String?
  billImage     String?
  date          DateTime        @default(now())
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  items ExpenseItem[]

  @@index([profileId])
  @@index([categoryId])
  @@index([profileId, date])
  @@index([profileId, paymentMethod])
  @@unique([profileId, expenseNo])
}

model ExpenseItem {
  id        String  @id @default(cuid())
  expenseId String
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  name      String
  amount    Decimal @db.Decimal(15, 2)
}

model ExpenseCategory {
  id        String    @id @default(cuid())
  profileId String
  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name      String
  isDefault Boolean   @default(false)
  createdAt DateTime  @default(now())

  expenses Expense[]

  @@unique([profileId, name])
  @@index([profileId])
}

// ─────────────────────────────────────────
// INCOME
// ─────────────────────────────────────────

model Income {
  id            String         @id @default(cuid())
  profileId     String
  profile       Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  incomeNo      Int
  categoryId    String
  category      IncomeCategory @relation(fields: [categoryId], references: [id])
  totalAmount   Decimal        @db.Decimal(15, 2)
  paymentMethod PaymentMethod  @default(CASH)
  remarks       String?
  billImage     String?
  date          DateTime       @default(now())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  items IncomeItem[]

  @@index([profileId])
  @@index([categoryId])
  @@index([profileId, date])
  @@index([profileId, paymentMethod])
  @@unique([profileId, incomeNo])
}

model IncomeItem {
  id       String  @id @default(cuid())
  incomeId String
  income   Income  @relation(fields: [incomeId], references: [id], onDelete: Cascade)
  name     String
  amount   Decimal @db.Decimal(15, 2)
}

model IncomeCategory {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  incomes Income[]

  @@unique([profileId, name])
  @@index([profileId])
}

// ─────────────────────────────────────────
// BANK ACCOUNTS
// ─────────────────────────────────────────

model BankAccount {
  id             String   @id @default(cuid())
  profileId      String
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  type           String   @default("Bank Account")
  bankName       String?
  holderName     String?
  accountNumber  String?
  currentBalance Decimal  @default(0) @db.Decimal(15, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([profileId])
}

// ─────────────────────────────────────────
// TRANSACTIONS (unified ledger)
// ─────────────────────────────────────────

model Transaction {
  id            String          @id @default(cuid())
  profileId     String
  profile       Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  type          TransactionType
  referenceId   String
  amount        Decimal         @db.Decimal(15, 2)
  description   String?
  date          DateTime        @default(now())
  createdAt     DateTime        @default(now())

  @@index([profileId])
  @@index([date])
  @@index([profileId, date])
  @@index([profileId, type])
}

enum TransactionType {
  EXPENSE
  INCOME
  PAYMENT_IN
  PAYMENT_OUT
  SALE
  PURCHASE
}

// ─────────────────────────────────────────
// REMINDERS
// ─────────────────────────────────────────

model Reminder {
  id          String       @id @default(cuid())
  profileId   String
  profile     Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title       String
  type        ReminderType @default(TASK)
  dueDate     DateTime
  isCompleted Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([profileId])
}

enum ReminderType {
  PAYMENT
  TASK
}

// ─────────────────────────────────────────
// NOTES (Notebook)
// ─────────────────────────────────────────

model Note {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title     String?
  body      String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
}

// ─────────────────────────────────────────
// BILL IMAGES (gallery)
// ─────────────────────────────────────────

model BillImage {
  id          String   @id @default(cuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  url         String
  fileName    String?
  referenceId String?
  refType     String?  // "expense" | "income" | "payment"
  createdAt   DateTime @default(now())

  @@index([profileId])
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  type        String
  category    String   @default("GENERAL") // "GENERAL", "SALES", "PURCHASE", "PAYMENT", "REMINDER", "SYSTEM"
  priority    String   @default("NORMAL") // "LOW", "NORMAL", "HIGH", "URGENT"
  message     String
  link        String?
  isRead      Boolean  @default(false)
  expiresAt   DateTime?
  readAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([profileId])
  @@index([userId, isRead])
  @@index([userId, category])
  @@index([userId, priority])
  @@index([expiresAt])
}

// ─────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  profileId String
  action    String   // "CREATE", "UPDATE", "DELETE", "VIEW", "EXPORT", "LOGIN", "LOGOUT", etc.
  resource  String   // "SALE", "PURCHASE", "PARTY", "ITEM", "EXPENSE", "INCOME", etc.
  resourceId String?
  details   String?  // JSON string with additional details
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([profileId])
  @@index([profileId, action])
  @@index([profileId, resource])
  @@index([createdAt])
}

model NotificationPreference {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  category  String   // "GENERAL", "SALES", "PURCHASE", "PAYMENT", "REMINDER", "SYSTEM"
  channel   String   @default("IN_APP") // "IN_APP", "EMAIL", "PUSH", "SMS"
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, profileId, category, channel])
  @@index([userId])
  @@index([profileId])
}

// ─────────────────────────────────────────
// INVENTORY & ITEMS
// ─────────────────────────────────────────

model Item {
  id             String   @id @default(cuid())
  profileId      String
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name           String
  sku            String?
  barcode        String?
  purchasePrice  Decimal  @default(0) @db.Decimal(15, 2)
  sellingPrice   Decimal  @default(0) @db.Decimal(15, 2)
  stockQuantity  Int      @default(0)
  unit           String?
  type           String   @default("PRODUCT") // "PRODUCT" | "SERVICE"
  description    String?  @db.Text
  specifications String?  @db.Text
  images         String[] // Array of image URLs
  brand          String?
  manufacturer   String?
  supplierId     String?
  supplier       Party?   @relation("ItemSupplier", fields: [supplierId], references: [id])
  reorderPoint   Int      @default(10)
  maxStock       Int?
  weight         Decimal? @db.Decimal(10, 3)
  dimensions     String?  // JSON string for dimensions
  shelfLocation  String?
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  saleItems      SaleItem[]
  purchaseItems  PurchaseItem[]
  quotationItems QuotationItem[]
  salesReturnItems SalesReturnItem[]
  purchaseReturnItems PurchaseReturnItem[]
  stockMovements StockMovement[]
  itemBatches    ItemBatch[]
  itemVariants   ItemVariant[]
  itemLocations  ItemLocation[]

  categoryId     String?
  category       ItemCategory? @relation(fields: [categoryId], references: [id])

  @@index([profileId])
  @@index([profileId, deletedAt])
  @@index([profileId, barcode])
  @@index([profileId, sku])
  @@index([supplierId])
  @@index([categoryId])
  @@index([stockQuantity])
  @@index([deletedAt])
}

model ItemCategory {
  id        String    @id @default(cuid())
  profileId String
  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime  @default(now())

  items     Item[]

  @@unique([profileId, name])
  @@index([profileId])
}

model StockMovement {
  id          String   @id @default(cuid())
  itemId      String
  item        Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  type        String   // "ADD", "REDUCE", "SALE", "PURCHASE", "ADJUSTMENT", "TRANSFER_IN", "TRANSFER_OUT"
  quantity    Int
  previousQty Int
  newQty      Int
  reason      String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  referenceId String?  // Reference to sale, purchase, etc.
  referenceType String? // "SALE", "PURCHASE", "ADJUSTMENT", "TRANSFER"
  batchId     String?
  locationId  String?
  createdAt   DateTime @default(now())

  @@index([itemId])
  @@index([profileId])
  @@index([userId])
  @@index([createdAt])
  @@index([referenceId])
}

// Item Batch/Lot Tracking
model ItemBatch {
  id          String   @id @default(cuid())
  itemId      String
  item        Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  profileId   String
  batchNumber String
  expiryDate  DateTime?
  quantity    Int
  purchasePrice Decimal @db.Decimal(15, 2)
  supplierId  String?
  supplier    Party?   @relation(fields: [supplierId], references: [id])
  locationId  String?
  location    ItemLocation? @relation(fields: [locationId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([itemId])
  @@index([profileId])
  @@index([batchNumber])
  @@index([expiryDate])
}

// Item Variants (size, color, etc.)
model ItemVariant {
  id          String   @id @default(cuid())
  itemId      String
  item        Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  profileId   String
  name        String   // e.g., "Red", "Large", "XL"
  type        String   // "COLOR", "SIZE", "MATERIAL", "STYLE"
  sku         String?
  barcode     String?
  priceAdjust Decimal  @default(0) @db.Decimal(15, 2) // Price difference from base price
  stockQuantity Int     @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([itemId])
  @@index([profileId])
  @@index([type])
}

// Item Locations (multiple warehouses/locations)
model ItemLocation {
  id          String   @id @default(cuid())
  itemId      String
  item        Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  profileId   String
  name        String   // e.g., "Warehouse A", "Store Front", "Back Room"
  address     String?
  stockQuantity Int   @default(0)
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  batches     ItemBatch[]

  @@index([itemId])
  @@index([profileId])
  @@index([isDefault])
}

// ─────────────────────────────────────────
// SALES (Invoices)
// ─────────────────────────────────────────

model Sale {
  id            String    @id @default(cuid())
  profileId     String
  profile       Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  invoiceNo     Int
  partyId       String?
  party         Party?    @relation(fields: [partyId], references: [id])
  totalAmount   Decimal   @db.Decimal(15, 2)
  discount      Decimal   @default(0) @db.Decimal(15, 2)
  tax           Decimal   @default(0) @db.Decimal(15, 2)
  grandTotal    Decimal   @db.Decimal(15, 2)
  receivedAmount Decimal  @default(0) @db.Decimal(15, 2)
  paymentMethod PaymentMethod @default(CASH)
  status        String    @default("PAID") // "PAID", "UNPAID", "PARTIAL"
  remarks       String?
  date          DateTime  @default(now())
  dueDate       DateTime?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  items         SaleItem[]
  salesReturns  SalesReturn[]
  payments      Payment[]

  @@index([profileId])
  @@index([profileId, deletedAt])
  @@index([partyId])
  @@index([profileId, date])
  @@index([profileId, status])
  @@index([profileId, partyId])
  @@index([deletedAt])
  @@unique([profileId, invoiceNo])
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  itemId    String?
  item      Item?   @relation(fields: [itemId], references: [id])
  name      String  // Captured at time of sale
  quantity  Int
  rate      Decimal @db.Decimal(15, 2)
  amount    Decimal @db.Decimal(15, 2)
}

model Payment {
  id            String    @id @default(cuid())
  profileId     String
  profile       Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  saleId        String
  sale          Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  partyId       String?
  party         Party?    @relation(fields: [partyId], references: [id])
  amount        Decimal   @db.Decimal(15, 2)
  paymentMethod PaymentMethod @default(CASH)
  date          DateTime  @default(now())
  remarks       String?
  createdAt     DateTime  @default(now())

  @@index([profileId])
  @@index([saleId])
  @@index([partyId])
}

model Discount {
  id            String    @id @default(cuid())
  profileId     String
  profile       Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name          String
  type          String    @default("PERCENTAGE") // "PERCENTAGE" | "FIXED_AMOUNT"
  value         Decimal   @db.Decimal(15, 2)
  minValue      Decimal?  @db.Decimal(15, 2)
  maxValue      Decimal?  @db.Decimal(15, 2)
  applicableTo  String?   // "ALL" | "SPECIFIC_ITEMS" | "SPECIFIC_CUSTOMERS"
  startDate     DateTime?
  endDate       DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([profileId])
}

// ─────────────────────────────────────────
// PURCHASES (Bills)
// ─────────────────────────────────────────

model Purchase {
  id            String    @id @default(cuid())
  profileId     String
  profile       Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  billNo        Int
  partyId       String?
  party         Party?    @relation(fields: [partyId], references: [id])
  totalAmount   Decimal   @db.Decimal(15, 2)
  discount      Decimal   @default(0) @db.Decimal(15, 2)
  tax           Decimal   @default(0) @db.Decimal(15, 2)
  grandTotal    Decimal   @db.Decimal(15, 2)
  paymentMethod PaymentMethod @default(CASH)
  status        String    @default("PAID") // "PAID", "UNPAID", "PARTIAL"
  remarks       String?
  date          DateTime  @default(now())
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  items         PurchaseItem[]
  purchaseReturns PurchaseReturn[]

  @@index([profileId])
  @@index([partyId])
  @@index([profileId, date])
  @@index([profileId, status])
  @@index([deletedAt])
  @@unique([profileId, billNo])
}

model PurchaseItem {
  id          String    @id @default(cuid())
  purchaseId  String
  purchase    Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  itemId      String?
  item        Item?     @relation(fields: [itemId], references: [id])
  name        String    // Captured at time of purchase
  quantity    Int
  rate        Decimal   @db.Decimal(15, 2)
  amount      Decimal   @db.Decimal(15, 2)
}

// ─────────────────────────────────────────
// QUOTATIONS
// ─────────────────────────────────────────

model Quotation {
  id            String    @id @default(cuid())
  profileId     String
  profile       Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  quotationNo   Int
  partyId       String?
  party         Party?    @relation(fields: [partyId], references: [id])
  totalAmount   Decimal   @db.Decimal(15, 2)
  discount      Decimal   @default(0) @db.Decimal(15, 2)
  tax           Decimal   @default(0) @db.Decimal(15, 2)
  grandTotal    Decimal   @db.Decimal(15, 2)
  status        String    @default("DRAFT") // "DRAFT", "SENT", "ACCEPTED", "REJECTED", "CONVERTED"
  remarks       String?
  validUntil    DateTime?
  date          DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  items         QuotationItem[]

  @@index([profileId])
  @@index([partyId])
  @@unique([profileId, quotationNo])
}

model QuotationItem {
  id           String     @id @default(cuid())
  quotationId  String
  quotation    Quotation  @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  itemId       String?
  item         Item?      @relation(fields: [itemId], references: [id])
  name         String     // Captured at time of quotation
  quantity     Int
  rate         Decimal    @db.Decimal(15, 2)
  amount       Decimal    @db.Decimal(15, 2)
}

// ─────────────────────────────────────────
// SALES RETURNS
// ─────────────────────────────────────────

model SalesReturn {
  id            String    @id @default(cuid())
  profileId     String
  profile       Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  returnNo      Int
  saleId        String?
  sale          Sale?     @relation(fields: [saleId], references: [id])
  partyId       String?
  party         Party?    @relation(fields: [partyId], references: [id])
  totalAmount   Decimal   @db.Decimal(15, 2)
  refundAmount  Decimal   @db.Decimal(15, 2)
  reason        String?
  status        String    @default("PENDING") // "PENDING", "APPROVED", "REJECTED", "COMPLETED"
  remarks       String?
  date          DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  items         SalesReturnItem[]

  @@index([profileId])
  @@index([saleId])
  @@index([partyId])
  @@unique([profileId, returnNo])
}

model SalesReturnItem {
  id             String       @id @default(cuid())
  salesReturnId  String
  salesReturn    SalesReturn  @relation(fields: [salesReturnId], references: [id], onDelete: Cascade)
  itemId         String?
  item           Item?        @relation(fields: [itemId], references: [id])
  name           String       // Captured at time of return
  quantity       Int
  rate           Decimal      @db.Decimal(15, 2)
  amount         Decimal      @db.Decimal(15, 2)
}

// ─────────────────────────────────────────
// PURCHASE RETURNS
// ─────────────────────────────────────────

model PurchaseReturn {
  id            String    @id @default(cuid())
  profileId     String
  profile       Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  returnNo      Int
  purchaseId    String?
  purchase      Purchase? @relation(fields: [purchaseId], references: [id])
  partyId       String?
  party         Party?    @relation(fields: [partyId], references: [id])
  totalAmount   Decimal   @db.Decimal(15, 2)
  refundAmount  Decimal   @db.Decimal(15, 2)
  reason        String?
  status        String    @default("PENDING") // "PENDING", "APPROVED", "REJECTED", "COMPLETED"
  remarks       String?
  date          DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  items         PurchaseReturnItem[]

  @@index([profileId])
  @@index([purchaseId])
  @@index([partyId])
  @@unique([profileId, returnNo])
}

model PurchaseReturnItem {
  id                String         @id @default(cuid())
  purchaseReturnId  String
  purchaseReturn    PurchaseReturn @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)
  itemId            String?
  item              Item?          @relation(fields: [itemId], references: [id])
  name              String         // Captured at time of return
  quantity          Int
  rate              Decimal        @db.Decimal(15, 2)
  amount            Decimal        @db.Decimal(15, 2)
}

